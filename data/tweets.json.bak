        "url": "blob:https://x.com/69a301f8-f272-4d03-addc-e109c2f552d3"
      }
    ],
    "profile": "buzzhaber",
    "text": "Burak Özçivit, Barzani ailesinin Pavilion şirketiyle ilgili bir soruya yanıt vererek dikkat çekti.",
    "time": "2025-04-07T17:26:41.000Z",
    "video": true
  },
  {
