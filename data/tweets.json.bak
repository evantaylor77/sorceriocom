      }
    ],
    "profile": "buzzhaber",
    "text": "Kadıköy Anadolu Lisesi öğrencileri ve mezunları, okul bahçesinde toplanarak öğretmenlerinin kadro dışı bırakılmasını protesto etti.",
    "time": "2025-04-11T11:42:45.000Z",
