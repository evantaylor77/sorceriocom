      {
        "type": "video",
        "url": "blob:https://x.com/a8d2f76b-e70c-4649-9b3f-778c576b7540"
      }
    ],
    "profile": "buzzhaber",
    "text": "Keçiören Belediye Başkanı Mesut Özarslan, bayram kutlamaları için Yeşilçam temalı bir video paylaştı.",
    "time": "2025-03-30T06:53:52.000Z",
    "video": true
  },
  {
